---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="section-heading">
  <h2>{title}</h2>
  {subtitle && <p class="section-heading__subtitle">{subtitle}</p>}
</div>

<style lang="scss">
  @use '../../styles/tokens' as *;

  .section-heading {
    text-align: center;
    margin-bottom: 3rem;

    h2 {
      color: $color-fg;
    }

    &__subtitle {
      margin-top: 1rem;
      color: $color-muted-fg;
      max-width: 40rem;
      margin-inline: auto;
    }
  }
</style>
