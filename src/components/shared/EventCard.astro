---
import Icon from './Icon.astro';

interface Props {
  title: string;
  date: string;
  sortDate: Date;
  location?: string;
  time?: string;
  type: string;
  registrationUrl?: string;
  externalUrl?: string;
  pageUrl?: string;
}

const { title, date, sortDate, location, time, type, registrationUrl, externalUrl, pageUrl } = Astro.props;

const hasSpecificDate = /\d{1,2}(st|nd|rd|th)/.test(date);
const day = hasSpecificDate ? sortDate.getDate() : null;
const month = hasSpecificDate ? sortDate.toLocaleDateString('en-US', { month: 'short' }).toUpperCase() : date;

const typeLabels: Record<string, string> = {
  summit: 'Summit',
  hackathon: 'Hackathon',
  lecture: 'Lecture',
  'case-event': 'Case Event',
  workshop: 'Workshop',
  other: 'Event',
};

const signupUrl = registrationUrl || externalUrl;
---

{pageUrl ? (
  <a href={pageUrl} class="event-card card event-card--linked">
    <div class="event-card__date-badge">
      {day && <span class="event-card__day">{day}</span>}
      <span class="event-card__month">{month}</span>
    </div>
    <div class="event-card__details">
      <h3 class="event-card__title">{title}</h3>
      <div class="event-card__meta">
        {location && (
          <span class="event-card__meta-item">
            <Icon name="map-pin" size={14} /> {location}
          </span>
        )}
        {time && (
          <span class="event-card__meta-item">
            <Icon name="clock" size={14} /> {time}
          </span>
        )}
      </div>
      <span class="event-card__type">{typeLabels[type] || type}</span>
    </div>
  </a>
) : (
  <div class="event-card card">
    <div class="event-card__date-badge">
      {day && <span class="event-card__day">{day}</span>}
      <span class="event-card__month">{month}</span>
    </div>
    <div class="event-card__details">
      <h3 class="event-card__title">{title}</h3>
      <div class="event-card__meta">
        {location && (
          <span class="event-card__meta-item">
            <Icon name="map-pin" size={14} /> {location}
          </span>
        )}
        {time && (
          <span class="event-card__meta-item">
            <Icon name="clock" size={14} /> {time}
          </span>
        )}
      </div>
      <span class="event-card__type">{typeLabels[type] || type}</span>
      {signupUrl && (
        <a href={signupUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--sm" style="margin-top: 0.75rem;">
          Register
        </a>
      )}
    </div>
  </div>
)}
