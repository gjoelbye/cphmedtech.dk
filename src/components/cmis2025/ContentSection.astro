---
import { Image } from 'astro:assets';

interface Props {
  heading: string;
  subtitle?: string;
  imageSrc: ImageMetadata;
  imageAlt: string;
  reversed?: boolean;
}

const { heading, subtitle, imageSrc, imageAlt, reversed = false } = Astro.props;
---

<section class="content-section">
  <div class:list={['content-section__grid', { 'content-section__grid--reversed': reversed }]}>
    <div class="content-section__image">
      <Image
        src={imageSrc}
        alt={imageAlt}
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, 50vw"
        loading="lazy"
        class="content-section__img"
      />
    </div>
    <div class="content-section__text">
      <h2>{heading}</h2>
      {subtitle && <p class="content-section__subtitle">{subtitle}</p>}
      <div class="content-section__body">
        <slot />
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/tokens' as *;
  @use '../../styles/mixins' as *;

  .content-section {
    padding: 4rem 0;
    @include container(72rem);
  }

  .content-section__grid {
    display: grid;
    gap: 3rem;
    align-items: center;

    @include respond-to($bp-md) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .content-section__grid--reversed {
    @include respond-to($bp-md) {
      .content-section__image {
        order: 2;
      }

      .content-section__text {
        order: 1;
      }
    }
  }

  .content-section__img {
    width: 100%;
    height: 20rem;
    object-fit: cover;
    border-radius: $radius-lg;
  }

  .content-section__text {
    h2 {
      margin-bottom: 0.5rem;
    }
  }

  .content-section__subtitle {
    font-size: 1rem;
    font-weight: 500;
    color: $color-primary;
    margin-bottom: 1rem;
  }

  .content-section__body {
    color: $color-muted-fg;

    p + p {
      margin-top: 1rem;
    }
  }
</style>
