---
import { Image } from 'astro:assets';
import Button from '../shared/Button.astro';
import event1 from '../../assets/images/event-1.jpg';
import event2 from '../../assets/images/event-2.jpg';
import event3 from '../../assets/images/event-3.jpg';
import event4 from '../../assets/images/event-4.jpg';
import event5 from '../../assets/images/event-5.jpg';

const images = [
  { src: event1, alt: 'CPH MedTech event 1' },
  { src: event2, alt: 'CPH MedTech event 2' },
  { src: event3, alt: 'CPH MedTech event 3' },
  { src: event4, alt: 'CPH MedTech event 4' },
  { src: event5, alt: 'CPH MedTech event 5' },
];
---

<section class="collage">
  <div class="collage__grid">
    {images.map((img, i) => (
      <div class:list={['collage__cell', { 'collage__cell--hidden-sm': i >= 2, 'collage__cell--hidden-md': i >= 3 }]}>
        <Image
          src={img.src}
          alt={img.alt}
          widths={[400, 800]}
          sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 20vw"
          loading="lazy"
          class="collage__img"
        />
      </div>
    ))}
  </div>
  <div class="collage__overlay">
    <div class="collage__content">
      <h2>Interested in supporting us?</h2>
      <p>
        As a non-profit student organisation, we rely on the support of external funding.
        If you are interested in supporting us or becoming a member, you are more than welcome to contact us.
      </p>
      <div class="collage__actions">
        <Button href="/contact/" variant="primary" premium>
          Contact Us
        </Button>
        <Button href="/contact/" variant="outline" class="collage__btn-outline">
          Become a Sponsor
        </Button>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/tokens' as *;
  @use '../../styles/mixins' as *;

  .collage {
    position: relative;
  }

  .collage__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;

    @include respond-to($bp-md) {
      grid-template-columns: repeat(3, 1fr);
    }

    @include respond-to($bp-lg) {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .collage__cell {
    aspect-ratio: 4 / 3;
    overflow: hidden;

    &--hidden-sm {
      display: none;

      @include respond-to($bp-md) {
        display: block;
      }
    }

    &--hidden-md {
      display: none;

      @include respond-to($bp-lg) {
        display: block;
      }
    }
  }

  .collage__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }

  .collage__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .collage__content {
    @include container;
    max-width: 56rem;
    text-align: center;
    color: #fff;

    h2 {
      color: #fff;
      margin-bottom: 1rem;
    }

    p {
      color: rgba(255, 255, 255, 0.9);
      max-width: 36rem;
      margin: 0 auto 2rem;
    }
  }

  .collage__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .collage__btn-outline {
    color: #fff;
    border-color: #fff;

    &:hover {
      background: #fff;
      color: $color-fg;
    }
  }
</style>
