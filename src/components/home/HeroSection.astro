---
import { Image } from 'astro:assets';
import Button from '../shared/Button.astro';
import heroBackground from '../../assets/images/hero-background.jpg';
---

<section class="hero">
  <div class="hero__bg">
    <Image
      src={heroBackground}
      alt=""
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="hero__img"
    />
    <div class="hero__overlay"></div>
  </div>
  <div class="hero__content">
    <h1 class="hero__title animate-fade-up">Copenhagen MedTech</h1>
    <div class="hero__divider animate-fade-up animate-delay-1"></div>
    <p class="hero__subtitle animate-fade-up animate-delay-1">Shaping the future of MedTech</p>
    <p class="hero__description animate-fade-up animate-delay-2">
      A student organisation connecting students and stakeholders in the MedTech industry through our summit and other events.
    </p>
    <div class="hero__cta animate-fade-up animate-delay-3">
      <Button href="/contact/" variant="outline" size="lg" class="hero__btn">
        Contact Us
      </Button>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/tokens' as *;
  @use '../../styles/mixins' as *;

  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    padding: 5rem 1rem;
    text-align: center;
  }

  .hero__title {
    font-size: 3rem;
    font-weight: 700;
    color: #fff;

    @include respond-to($bp-md) {
      font-size: 4.5rem;
    }
  }

  .hero__divider {
    width: 8rem;
    height: 2px;
    background: #fff;
    margin: 1.5rem auto;
  }

  .hero__subtitle {
    font-size: 1.5rem;
    font-weight: 300;
    color: #fff;

    @include respond-to($bp-md) {
      font-size: 1.875rem;
    }
  }

  .hero__description {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 36rem;
    margin: 1.5rem auto 0;

    @include respond-to($bp-md) {
      font-size: 1.25rem;
    }
  }

  .hero__cta {
    margin-top: 2rem;
  }

  .hero__btn {
    color: #fff;
    border-color: #fff;

    &:hover {
      background: #fff;
      color: $color-fg;
    }
  }
</style>
