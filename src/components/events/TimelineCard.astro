---
interface Props {
  title: string;
  date: string;
  description: string;
  side: 'left' | 'right';
  index: number;
}

const { title, date, description, side, index } = Astro.props;
---

<div
  class={`timeline-card timeline-card--${side}`}
  style={`transition-delay: ${index * 100}ms`}
>
  <div class="timeline-card__dot"></div>
  <div class="timeline-card__content card-premium">
    <h3 class="timeline-card__title">{title}</h3>
    <span class="timeline-card__date">{date}</span>
    <p class="timeline-card__description">{description}</p>
  </div>
</div>

<style lang="scss">
  @use '../../styles/tokens' as *;
  @use '../../styles/mixins' as *;

  .timeline-card {
    position: relative;
    margin-bottom: 2rem;
    width: 100%;
    padding-left: 2.5rem;

    @include respond-to($bp-md) {
      width: calc(50% - 2rem);
      padding-left: 0;
    }
  }

  .timeline-card--left {
    @include respond-to($bp-md) {
      margin-right: auto;
      text-align: right;
    }
  }

  .timeline-card--right {
    @include respond-to($bp-md) {
      margin-left: auto;
    }
  }

  .timeline-card__dot {
    position: absolute;
    width: 1rem;
    height: 1rem;
    background-color: $color-primary;
    border: 4px solid $color-bg;
    border-radius: 50%;
    box-shadow: $shadow-glow;
    top: 1.5rem;
    left: -0.5rem;
    z-index: 2;

    @include respond-to($bp-md) {
      .timeline-card--left & {
        right: calc(-2rem - 0.5rem);
        left: auto;
      }

      .timeline-card--right & {
        left: calc(-2rem - 0.5rem);
      }
    }
  }

  .timeline-card__content {
    padding: 1.5rem;

    &:hover {
      box-shadow: $shadow-strong;
    }
  }

  .timeline-card__title {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .timeline-card__date {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
    color: $color-primary;
    margin-bottom: 0.75rem;
  }

  .timeline-card__description {
    font-size: 0.875rem;
    color: $color-muted-fg;
    line-height: 1.6;
  }
</style>
