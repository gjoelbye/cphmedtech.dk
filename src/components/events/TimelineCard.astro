---
interface Props {
  title: string;
  date: string;
  description: string;
  side: 'left' | 'right';
  index: number;
  type?: string;
}

const { title, date, description, side, index, type } = Astro.props;

const typeLabels: Record<string, string> = {
  summit: 'Summit',
  hackathon: 'Hackathon',
  lecture: 'Lecture',
  'case-event': 'Case Event',
  workshop: 'Workshop',
  other: 'Event',
};
---

<div
  class={`timeline-card timeline-card--${side}`}
  style={`transition-delay: ${index * 50}ms`}
>
  <div class="timeline-card__dot"></div>
  <div class="timeline-card__content card-premium">
    <h3 class="timeline-card__title">{title}</h3>
    <div class="timeline-card__meta">
      <span class="timeline-card__date">{date}</span>
      {type && <span class={`timeline-card__type timeline-card__type--${type}`}>{typeLabels[type] || type}</span>}
    </div>
    <p class="timeline-card__description">{description}</p>
  </div>
</div>

<style lang="scss">
  @use '../../styles/tokens' as *;
  @use '../../styles/mixins' as *;

  .timeline-card {
    position: relative;
    margin-bottom: 2rem;
    width: 100%;
    padding-left: 2.5rem;

    @include respond-to($bp-md) {
      width: calc(50% - 2rem);
      padding-left: 0;
    }
  }

  .timeline-card--left {
    @include respond-to($bp-md) {
      margin-right: auto;
    }
  }

  .timeline-card--right {
    @include respond-to($bp-md) {
      margin-left: auto;
    }
  }

  .timeline-card__dot {
    position: absolute;
    width: 1rem;
    height: 1rem;
    background-color: $color-primary;
    border: 4px solid $color-bg;
    border-radius: 50%;
    box-shadow: $shadow-glow;
    top: 1.5rem;
    left: -0.625rem;
    z-index: 2;

    @include respond-to($bp-md) {
      .timeline-card--left & {
        right: calc(-2rem - 0.5rem);
        left: auto;
      }

      .timeline-card--right & {
        left: calc(-2rem - 0.5rem);
      }
    }
  }

  .timeline-card__content {
    padding: 1.5rem;

    &:hover {
      transform: translateY(-2px);
      box-shadow: $shadow-strong;
    }
  }

  .timeline-card__title {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .timeline-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .timeline-card__type {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.5rem;
    border-radius: $radius-full;
    background-color: rgba($color-primary, 0.1);
    color: $color-primary;

    &--summit {
      background-color: rgba($color-primary, 0.1);
      color: $color-primary;
    }

    &--hackathon {
      background-color: rgba($color-success, 0.1);
      color: $color-success;
    }

    &--lecture {
      background-color: rgba($color-muted-fg, 0.1);
      color: $color-muted-fg;
    }

    &--case-event {
      background-color: rgba($color-accent, 0.1);
      color: $color-accent;
    }

    &--workshop {
      background-color: rgba(168, 85, 247, 0.1);
      color: rgb(168, 85, 247);
    }
  }

  .timeline-card__date {
    font-size: 0.875rem;
    font-weight: 500;
    color: $color-primary;
  }

  .timeline-card__description {
    font-size: 0.875rem;
    color: $color-muted-fg;
    line-height: 1.6;
  }
</style>
