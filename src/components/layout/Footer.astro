---
import Icon from '../shared/Icon.astro';

const currentYear = new Date().getFullYear();

const exploreLinks = [
  { label: 'About', href: '/about/' },
  { label: 'Events', href: '/events/' },
  { label: 'Partners', href: '/partners/' },
  { label: 'Blog', href: '/blog/' },
];

const connectLinks = [
  { label: 'Contact', href: '/contact/' },
  { label: 'Join Us', href: '/join/' },
];

const socialLinks = [
  { name: 'linkedin', label: 'LinkedIn', href: 'https://www.linkedin.com/company/copenhagen-medtech/' },
  { name: 'instagram', label: 'Instagram', href: 'https://www.instagram.com/cph_medtech/?hl=en' },
  { name: 'facebook', label: 'Facebook', href: 'https://www.facebook.com/p/Copenhagen-MedTech-100083403373733/' },
];
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__grid">
      <div class="footer__brand">
        <img src="/logos/cm-circle-sticker.svg" alt="Copenhagen MedTech" class="footer__logo" width="40" height="40" />
        <p class="footer__tagline">Shaping the future of MedTech</p>
        <p class="footer__description">
          A student organisation connecting students and stakeholders in the MedTech industry through summits and events.
        </p>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Explore</h4>
        <ul class="footer__list">
          {exploreLinks.map((link) => (
            <li><a href={link.href} class="footer__link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Connect</h4>
        <ul class="footer__list">
          {connectLinks.map((link) => (
            <li><a href={link.href} class="footer__link">{link.label}</a></li>
          ))}
        </ul>
        <div class="footer__social">
          {socialLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label} class="footer__social-link">
              <Icon name={link.name} size={18} />
            </a>
          ))}
        </div>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Legal</h4>
        <ul class="footer__list">
          <li><a href="/privacy/" class="footer__link">Privacy Policy</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {currentYear} Copenhagen MedTech. All rights reserved.</p>
    </div>
  </div>
</footer>

<style lang="scss">
  @use '../../styles/tokens' as *;
  @use '../../styles/mixins' as *;

  .footer {
    background-color: $color-surface-dark;
    color: $color-overlay-text-muted;
    padding: 4rem 0 2rem;
  }

  .footer__inner {
    @include container($container-wide);
  }

  .footer__grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;

    @include respond-to($bp-sm) {
      grid-template-columns: repeat(2, 1fr);
    }

    @include respond-to($bp-lg) {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  .footer__brand {
    @include respond-to($bp-sm) {
      grid-column: span 2;
    }

    @include respond-to($bp-lg) {
      grid-column: span 1;
    }
  }

  .footer__logo {
    height: 2rem;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
    margin-bottom: 1rem;
  }

  .footer__tagline {
    font-size: 0.9375rem;
    font-weight: 600;
    color: $color-overlay-text;
  }

  .footer__description {
    font-size: 0.8125rem;
    margin-top: 0.5rem;
    line-height: 1.6;
    max-width: 24rem;
  }

  .footer__heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: $color-overlay-text;
    margin-bottom: 1rem;
  }

  .footer__list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: $color-overlay-text-muted;
    transition: color 0.2s ease;

    &:hover {
      color: $color-overlay-text;
    }
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .footer__social-link {
    color: $color-overlay-text-muted;
    transition: color 0.2s ease;

    &:hover {
      color: $color-overlay-text;
    }
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: 3rem;
    padding-top: 1.5rem;

    p {
      font-size: 0.8125rem;
      color: rgba(255, 255, 255, 0.4);
    }
  }
</style>
