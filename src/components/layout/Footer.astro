---
import Icon from '../shared/Icon.astro';

const currentYear = new Date().getFullYear();

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Past Events', href: '/past-events/' },
  { label: '2025', href: '/2025/' },
  { label: 'Our Partners', href: '/partners/' },
  { label: 'Contact', href: '/contact/' },
];

const socialLinks = [
  { name: 'linkedin', label: 'LinkedIn', href: 'https://www.linkedin.com/company/copenhagen-medtech/' },
  { name: 'instagram', label: 'Instagram', href: 'https://www.instagram.com/cph_medtech/?hl=en' },
  { name: 'facebook', label: 'Facebook', href: 'https://www.facebook.com/p/Copenhagen-MedTech-100083403373733/' },
];
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <p class="footer__name">Copenhagen MedTech</p>
        <p class="footer__tagline">Shaping the future of MedTech</p>
      </div>

      <nav class="footer__nav" aria-label="Footer navigation">
        <ul class="footer__links">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer__social">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.label}
            class="footer__social-link"
          >
            <Icon name={link.name} size={20} />
          </a>
        ))}
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {currentYear} Copenhagen MedTech. All rights reserved.</p>
    </div>
  </div>
</footer>

<style lang="scss">
  @use '../../styles/tokens' as *;
  @use '../../styles/mixins' as *;

  .footer {
    background-color: $color-muted;
    border-top: 1px solid $color-border;
    padding: 3rem 0;

    @include respond-to($bp-md) {
      padding: 4rem 0;
    }
  }

  .footer__inner {
    @include container;
  }

  .footer__top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;

    @include respond-to($bp-md) {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: start;
      text-align: left;
      gap: 2rem;
    }
  }

  .footer__social {
    @include respond-to($bp-md) {
      justify-self: end;
    }
  }

  .footer__name {
    font-size: 1.125rem;
    font-weight: 700;
    color: $color-fg;
  }

  .footer__tagline {
    font-size: 0.875rem;
    color: $color-muted-fg;
    margin-top: 0.25rem;
  }

  .footer__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: $color-muted-fg;
    padding: 0.25rem 0;
    transition: color 0.3s ease;

    &:hover {
      color: $color-primary;
      text-decoration: underline;
    }
  }

  .footer__social {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .footer__social-link {
    color: $color-muted-fg;
    transition: color 0.3s ease;

    &:hover {
      color: $color-primary;
    }
  }

  .footer__bottom {
    border-top: 1px solid $color-border;
    margin-top: 2rem;
    padding-top: 1.5rem;
    text-align: center;

    @include respond-to($bp-md) {
      text-align: left;
    }

    p {
      font-size: 0.875rem;
      color: $color-muted-fg;
    }
  }
</style>
