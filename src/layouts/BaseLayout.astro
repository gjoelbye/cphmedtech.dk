---
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/layout/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import MobileMenu from '../components/layout/MobileMenu.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.scss';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalPath?: string;
  type?: 'website' | 'article';
}

const { title, description, ogImage, canonicalPath, type } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalPath={canonicalPath}
      type={type}
    >
      <slot name="head" />
    </BaseHead>
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="sr-only skip-link">Skip to content</a>
    <Header />
    <MobileMenu />
    <main id="main" class="main">
      <slot />
    </main>
    <section class="cta-strip">
      <div class="cta-strip__inner">
        <p class="cta-strip__text">Interested in Copenhagen MedTech?</p>
        <a href="/contact/" class="btn btn--outline-light btn--premium">Get in Touch</a>
      </div>
    </section>
    <Footer />
    <script src="../scripts/mobile-menu.ts"></script>
  </body>
</html>

<style lang="scss">
  @use '../styles/tokens' as *;
  @use '../styles/mixins' as *;

  .main {
    flex: 1;
    padding-top: $nav-height;
    background: linear-gradient(180deg, rgba($color-muted, 0.3) 0%, transparent 30%);
  }

  .cta-strip {
    background: $gradient-primary;
    padding: 3rem 0;
    text-align: center;
  }

  .cta-strip__inner {
    @include container;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;

    @include respond-to($bp-md) {
      flex-direction: row;
      justify-content: center;
    }
  }

  .cta-strip__text {
    font-size: 1.25rem;
    font-weight: 600;
    color: $color-overlay-text;
    letter-spacing: $letter-spacing-heading;
  }

  .skip-link {
    &:focus {
      position: fixed;
      top: 0.5rem;
      left: 0.5rem;
      z-index: 200;
      padding: 0.5rem 1rem;
      background: $color-primary;
      color: $color-primary-fg;
      border-radius: $radius;
      width: auto;
      height: auto;
      clip: auto;
      white-space: normal;
    }
  }
</style>
