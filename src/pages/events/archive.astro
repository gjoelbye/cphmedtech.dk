---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Timeline from '../../components/events/Timeline.astro';
import Button from '../../components/shared/Button.astro';
import Icon from '../../components/shared/Icon.astro';
---

<BaseLayout
  title="Event Archive"
  description="Explore Copenhagen MedTech's complete event history — summits, hackathons, lectures, and case events from 2022 to today."
>
  <section class="archive">
    <div class="archive__header">
      <a href="/events/" class="archive__back">
        <Icon name="arrow-left" size={16} />
        Back to Events
      </a>
      <h1>Event Archive</h1>
      <p>A timeline of Copenhagen MedTech events since our founding in 2022.</p>
    </div>
    <Timeline />
  </section>
</BaseLayout>

<style lang="scss">
  @use '../../styles/tokens' as *;
  @use '../../styles/mixins' as *;

  .archive {
    padding-block: 3rem;

    @include respond-to($bp-md) {
      padding-block: 4rem;
    }
  }

  .archive__header {
    @include container;
    text-align: center;
    margin-bottom: 3rem;

    h1 { margin-bottom: 1rem; }
    p { color: $color-fg-muted; max-width: 32rem; margin-inline: auto; }
  }

  .archive__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: $color-fg;
    margin-bottom: 1.5rem;
    transition: color 0.2s ease;

    &:hover { color: $color-primary; }
  }
</style>
