---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import CMISPreview from '../components/home/CMISPreview.astro';
import PhotoCollage from '../components/home/PhotoCollage.astro';
import PartnersGrid from '../components/home/PartnersGrid.astro';
---

<BaseLayout
  title="Shaping the Future of MedTech Innovation"
  description="Copenhagen MedTech is a student organisation connecting students and stakeholders in the MedTech industry through innovative summits and events."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Copenhagen MedTech",
      "url": "https://cphmedtech.dk",
      "description": "A student organisation connecting students and stakeholders in the MedTech industry through innovative summits and events.",
      "email": "info@copenhagenmedtech.org",
      "sameAs": [
        "https://www.linkedin.com/company/copenhagen-medtech/",
        "https://www.instagram.com/cph_medtech/",
        "https://www.facebook.com/p/Copenhagen-MedTech-100083403373733/"
      ]
    })} />
  </Fragment>
  <HeroSection />
  <CMISPreview />
  <PhotoCollage />
  <PartnersGrid />
</BaseLayout>
