---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/events/Timeline.astro';
---

<BaseLayout
  title="Past Events"
  description="Explore Copenhagen MedTech's event history — summits, hackathons, lectures, and case events from 2022 to today."
>
  <section class="past-events">
    <div class="past-events__header">
      <h1>Past Events</h1>
      <p>A timeline of Copenhagen MedTech events since our founding in 2022.</p>
    </div>
    <Timeline />
  </section>
</BaseLayout>

<style lang="scss">
  @use '../styles/tokens' as *;
  @use '../styles/mixins' as *;

  .past-events {
    padding-block: 3rem;

    @include respond-to($bp-md) {
      padding-block: 4rem;
    }
  }

  .past-events__header {
    @include container;
    text-align: center;
    margin-bottom: 3rem;

    h1 {
      margin-bottom: 1rem;
    }

    p {
      color: $color-muted-fg;
      max-width: 32rem;
      margin-inline: auto;
    }
  }
</style>
