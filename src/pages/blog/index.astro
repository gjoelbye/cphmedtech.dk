---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import BlogCard from '../../components/shared/BlogCard.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);
---

<PageLayout
  title="Blog"
  description="News, event recaps, and insights from Copenhagen MedTech."
>
  <div class="blog-page">
    <h1>Blog</h1>
    <p class="blog-page__intro">
      News, event recaps, and insights from Copenhagen MedTech.
    </p>

    {posts.length > 0 ? (
      <div class="blog-page__grid">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            date={new Date(post.data.publishDate)}
            description={post.data.description}
            slug={post.data.slug}
            coverImage={post.data.coverImage}
          />
        ))}
      </div>
    ) : (
      <div class="blog-page__empty">
        <p>Posts coming soon. Stay tuned.</p>
      </div>
    )}
  </div>
</PageLayout>

<style lang="scss">
  @use '../../styles/tokens' as *;
  @use '../../styles/mixins' as *;

  .blog-page {
    h1 { text-align: center; margin-bottom: 1rem; }
  }

  .blog-page__intro {
    text-align: center;
    color: $color-fg-muted;
    margin-bottom: 3rem;
  }

  .blog-page__grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;

    @include respond-to($bp-md) {
      grid-template-columns: repeat(2, 1fr);
    }

    @include respond-to($bp-lg) {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog-page__empty {
    text-align: center;
    padding: 4rem 2rem;
    background: $color-surface;
    border-radius: $radius-lg;

    p { color: $color-fg-muted; }
  }
</style>
